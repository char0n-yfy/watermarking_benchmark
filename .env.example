APP_ENV=development
WM_BENCH_DATA_ROOT=.
WM_BENCH_RESOURCES_ROOT=./resources
WM_BENCH_RUNS_ROOT=./runs
WM_BENCH_DB_PATH=./runs/wmbench.sqlite
API_HOST=127.0.0.1
API_PORT=8000
WM_BENCH_DEVICE=cpu
WM_BENCH_WORKER_POLL_SECONDS=2
WM_BENCH_RUN_TIMEOUT_SECONDS=3600
WM_BENCH_VENV=.venv
WM_BENCH_VENV_SYSTEM_SITE_PACKAGES=0
WM_BENCH_INSTALL_PYTHON_DEPS=1
WM_BENCH_INSTALL_SHARP_DEPS=1
WM_BENCH_PREPARE_PERCEPTUAL_WEIGHTS=1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# GitHub browse base for in-repo source paths shown in resource reference panels.
NEXT_PUBLIC_PROJECT_SOURCE_BASE_URL=https://github.com/char0n-yfy/watermarking_benchmark/blob/main
WM_BENCH_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:6006,http://127.0.0.1:6006

# Dataset object storage (Aliyun OSS, S3-compatible)
#
# Default mode: PUBLIC READ — no AccessKey needed on each machine.
# Admin once: OSS console → bucket watermarking-benchmark → set wmbench/datasets/* public-read
# (or whole bucket public-read for internal team use).
#
# Clone, start scripts, open /resources — download works without filling keys below.
#
# Optional: set WM_BENCH_OSS_PUBLIC_READ=false and fill ACCESS_KEY/SECRET for private buckets.
#
# Upload layout:
#   {prefix}/datasets/{dataset_id}/compact-1000.zip
#   {prefix}/datasets/{dataset_id}/manifest.txt
#   {prefix}/datasets/{dataset_id}/images/000001.jpg
WM_BENCH_OSS_ENABLED=true
WM_BENCH_OSS_PUBLIC_READ=true
WM_BENCH_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
WM_BENCH_OSS_BUCKET=watermarking-benchmark
WM_BENCH_OSS_PREFIX=wmbench
WM_BENCH_OSS_REGION=oss-cn-shanghai
WM_BENCH_OSS_ACCESS_KEY=
WM_BENCH_OSS_SECRET_KEY=
WM_BENCH_OSS_PRESIGN_EXPIRES=3600
