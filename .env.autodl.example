APP_ENV=autodl
WM_BENCH_DATA_ROOT=/root/autodl-fs/wm-bench
WM_BENCH_RESOURCES_ROOT=/root/autodl-fs/wm-bench/resources
WM_BENCH_RUNS_ROOT=/root/autodl-tmp/wm-bench/runs
WM_BENCH_DB_PATH=/root/autodl-fs/wm-bench/state/wmbench.sqlite
WM_BENCH_DEVICE=cuda:0
WM_BENCH_WORKER_POLL_SECONDS=2
WM_BENCH_RUN_TIMEOUT_SECONDS=3600
WM_BENCH_VENV=.venv
WM_BENCH_VENV_SYSTEM_SITE_PACKAGES=1
API_HOST=0.0.0.0
API_PORT=6006
NEXT_PUBLIC_API_BASE_URL=

# OSS dataset download (public-read by default; no AccessKey required)
WM_BENCH_OSS_ENABLED=true
WM_BENCH_OSS_PUBLIC_READ=true
WM_BENCH_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
WM_BENCH_OSS_BUCKET=watermarking-benchmark
WM_BENCH_OSS_PREFIX=wmbench
WM_BENCH_OSS_REGION=oss-cn-shanghai
