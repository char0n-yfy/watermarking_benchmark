APP_ENV=autodl
WM_BENCH_DATA_ROOT=/root/autodl-fs/wm-bench
WM_BENCH_RESOURCES_ROOT=./resources
WM_BENCH_RUNS_ROOT=./runs
WM_BENCH_DB_PATH=/root/autodl-fs/wm-bench/state/wmbench.sqlite
WM_BENCH_DEVICE=cuda:0
WM_BENCH_WORKER_POLL_SECONDS=2
WM_BENCH_RUN_TIMEOUT_SECONDS=3600

# Centralized execution/concurrency tuning
WM_BENCH_WATERMARK_CPU_WORKERS=8
WM_BENCH_WATERMARK_CPU_WORKERS_BY_METHOD=invisible-watermark-dwtdct=1,invisible-watermark-dwtdctsvd=1,traditional-spread-dct=24
WM_BENCH_ATTACK_CPU_WORKERS=16
WM_BENCH_ATTACK_CPU_WORKERS_BY_METHOD=brightness=24,contrast=24,gaussian_blur=32,gaussian_noise=24,jpeg=24,resize=32,rotation=32,resized_crop=32,erasing=32
WM_BENCH_QUALITY_CPU_WORKERS=16
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
WM_BENCH_PERCEPTUAL_DEVICE=cuda:0
WM_BENCH_PERCEPTUAL_BATCH_SIZE=4
WM_BENCH_PERCEPTUAL_BATCH_SIZES=lpips=16,dists=4
WM_BENCH_WATERMARK_EMBED_BATCH_SIZE=4
WM_BENCH_WATERMARK_EMBED_BATCH_SIZES=chunkyseal=16,cin=32,hidden=32,invisible-watermark-rivagan=2,invismark=16,maskwm-d32=16,mbrs=16,pimog=16,pixelseal=16,rawatermark=8,ssl-watermarking=32,stegastamp=16,trustmark-c=4,trustmark-q=32,videoseal=8,vine=1,wam=8
WM_BENCH_WATERMARK_EXTRACT_BATCH_SIZE=4
WM_BENCH_WATERMARK_EXTRACT_BATCH_SIZES=chunkyseal=32,cin=32,hidden=8,invisible-watermark-rivagan=1,invismark=1,maskwm-d32=8,mbrs=4,pimog=8,pixelseal=32,rawatermark=16,ssl-watermarking=2,stegastamp=16,trustmark-c=32,trustmark-q=16,videoseal=16,vine=1,wam=32
WM_BENCH_WATERMARK_BATCH_SIZE=4
WM_BENCH_WATERMARK_BATCH_SIZES=

WM_BENCH_VENV=.venv
WM_BENCH_VENV_SYSTEM_SITE_PACKAGES=1
WM_BENCH_INSTALL_PYTHON_DEPS=1
WM_BENCH_INSTALL_SHARP_DEPS=1
WM_BENCH_PREPARE_PERCEPTUAL_WEIGHTS=1
WM_BENCH_AUTO_INSTALL_NODE=1
WM_BENCH_AUTO_INSTALL_SCREEN=1
WM_BENCH_NODE_VERSION=20
WM_BENCH_PNPM_VERSION=9.15.0
WM_BENCH_LOG_DIR=./runs/logs
API_HOST=0.0.0.0
API_PORT=6006
NEXT_PUBLIC_API_BASE_URL=
WM_BENCH_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:6006,http://127.0.0.1:6006

# OSS dataset download (public-read by default; no AccessKey required)
WM_BENCH_OSS_ENABLED=true
WM_BENCH_OSS_PUBLIC_READ=true
WM_BENCH_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
WM_BENCH_OSS_BUCKET=watermarking-benchmark
WM_BENCH_OSS_PREFIX=wmbench
WM_BENCH_OSS_REGION=oss-cn-shanghai
